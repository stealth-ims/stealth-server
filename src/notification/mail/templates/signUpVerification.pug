extends baseEmail

block content
  p Dear #{fullName},
  p Thank you for registering with Stealth IMS. To complete your registration and activate your account, please verify your email address by clicking the link below.
  p
    a(href=verificationUrl, style="color: #1a73e8; text-decoration: underline;") Verify Your Account
  hr
  p Account Details:
  ul
    li Full Name: #{fullName}
    li Username: #{username}
    li Email: #{email}
    li Role: #{role}
    li Status: Pending Verification
  hr
  p If the button above doesn't work, copy and paste the following link into your browser:
  a(href=verificationUrl) #{verificationUrl}
  hr
  p If you have any questions or need assistance, please don't hesitate to contact our support team.
  p We appreciate your time and look forward to welcoming you as a verified member of our platform!
  p Best Regards,
  p Stealth