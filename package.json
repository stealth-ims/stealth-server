{
  "name": "stealth-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT License",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "db:create": "dotenv -e $YARN_ENV -- yarn sequelize-cli db:create",
    "db:drop": "dotenv -e $YARN_ENV -- yarn sequelize-cli db:drop",
    "db:reset": "yarn migrate:undo:all && yarn migrate:up",
    "db:seed:reset": "yarn migrate:undo:all && yarn migrate:up && yarn seed:all",
    "migrate:gen": "yarn sequelize-cli migration:generate --name ",
    "migrate:up": "yarn sequelize-cli db:migrate",
    "migrate:undo": "yarn sequelize-cli db:migrate:undo --name ",
    "migrate:undo:all": "yarn sequelize-cli db:migrate:undo:all",
    "seed:gen": "yarn sequelize-cli seed:generate --name ",
    "seed:all": "yarn sequelize-cli db:seed:all",
    "seed": "yarn sequelize-cli db:seed --seed ",
    "seed:undo:all": "yarn sequelize-cli db:seed:undo:all",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "dotenv -e .env.test.local -- jest",
    "test:watch": "dotenv -e .env.test.local -- jest --watch",
    "test:cov": "dotenv -e .env.test.local -- jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "dotenv -e .env.test.local -- jest --watch --no-cache --config ./test/jest-e2e.json",
    "migrate:test:up": " dotenv -e .env.test.local -- yarn sequelize-cli db:migrate",
    "migrate:undo:test:all": "dotenv -e .env.test.local -- yarn sequelize-cli db:migrate:undo:all",
    "sequelize:seed:test:all": "dotenv -e .env.test.local -- yarn sequelize-cli db:seed:all",
    "sequelize:seed:undo:test:all": "dotenv -e .env.test.local -- yarn sequelize-cli db:seed:undo:all",
    "pretest:e2e": "YARN_ENV=.env.test.local yarn db:create && yarn migrate:test:up",
    "posttest:e2e": "YARN_ENV=.env.test.local yarn db:drop",
    "prepare": "husky"
  },
  "dependencies": {
    "@json2csv/plainjs": "^7.0.6",
    "@json2csv/whatwg": "^7.0.6",
    "@logtail/node": "^0.5.2",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.11",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/platform-socket.io": "^11.0.11",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/sequelize": "^11.0.0",
    "@nestjs/swagger": "^11.0.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/websockets": "^11.0.11",
    "@sendgrid/mail": "^8.1.4",
    "africastalking": "^0.7.3",
    "axios": "^1.8.3",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.56.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.6.0",
    "date-fns": "^4.1.0",
    "js-yaml": "^4.1.0",
    "nestjs-twilio": "^4.4.0",
    "nodemailer": "^6.10.0",
    "pg": "^8.14.1",
    "pg-hstore": "^2.3.4",
    "pg-query-stream": "^4.10.3",
    "pug": "^3.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.6",
    "sequelize-typescript": "^2.1.6",
    "streamifier": "^0.1.1",
    "twilio": "^5.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.11",
    "@types/africastalking": "^0.6.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.4",
    "@types/pg-query-stream": "^3.4.0",
    "@types/sequelize": "^4.28.20",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "sequelize-cli": "^6.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "yarn format",
      "yarn lint"
    ],
    "*.{spec.js,spec.ts}": [
      "yarn test"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "modulePaths": [
      "<rootDir>"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
