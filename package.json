{
  "name": "stealth-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT License",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "db:create": "dotenv -e $YARN_ENV -- yarn sequelize-cli db:create",
    "db:drop": "dotenv -e $YARN_ENV -- yarn sequelize-cli db:drop",
    "migrate:reset": "yarn migrate:undo:all && yarn migrate:up && yarn seed:all",
    "migrate:gen": "yarn sequelize-cli migration:generate --name ",
    "migrate:up": "yarn sequelize-cli db:migrate",
    "migrate:undo": "yarn sequelize-cli db:migrate:undo",
    "migrate:undo:all": "yarn sequelize-cli db:migrate:undo:all",
    "seed:gen": "yarn sequelize-cli seed:generate --name ",
    "seed:all": "yarn sequelize-cli db:seed:all",
    "seed:undo:all": "yarn sequelize-cli db:seed:undo:all",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "dotenv -e .env.test.local -- jest",
    "test:watch": "dotenv -e .env.test.local -- jest --watch",
    "test:cov": "dotenv -e .env.test.local -- jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "dotenv -e .env.test.local -- jest --watch --no-cache --config ./test/jest-e2e.json",
    "migrate:test:up": " dotenv -e .env.test.local -- yarn sequelize-cli db:migrate",
    "migrate:undo:test:all": "dotenv -e .env.test.local -- yarn sequelize-cli db:migrate:undo:all",
    "sequelize:seed:test:all": "dotenv -e .env.test.local -- yarn sequelize-cli db:seed:all",
    "sequelize:seed:undo:test:all": "dotenv -e .env.test.local -- yarn sequelize-cli db:seed:undo:all",
    "pretest:e2e": "YARN_ENV=.env.test.local yarn db:create && yarn migrate:test:up",
    "posttest:e2e": "YARN_ENV=.env.test.local yarn db:drop",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/sequelize": "^10.0.1",
    "@nestjs/swagger": "^7.4.2",
    "@sendgrid/mail": "^8.1.3",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.5.0",
    "date-fns": "^4.1.0",
    "nodemailer": "^6.9.15",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "pug": "^3.0.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.3",
    "sequelize-typescript": "^2.1.6",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.16",
    "@types/sequelize": "^4.28.20",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.6",
    "jest": "^29.5.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.0.0",
    "sequelize-cli": "^6.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "yarn format",
      "yarn lint"
    ],
    "*.{spec.js,spec.ts}": [
      "yarn test"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "modulePaths": [
      "<rootDir>"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
